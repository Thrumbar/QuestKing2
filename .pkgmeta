# BigWigsMods packager metadata for QuestKing2 = Reborn.
# Keep package-as matching the actual addon folder and TOC basename:
#   QuestKing/QuestKing.toc
# Do not change this to the CurseForge slug unless the addon folder and TOC
# are also renamed and all hard-coded Interface\\AddOns\\QuestKing paths are updated.
package-as: QuestKing

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

enable-nolib-creation: no

ignore:
  - .github
  - .release
  - docs
  - tools
  - tests
  - '*.zip'
  - '*.7z'
  - '*.rar'
